{
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/careers",
      "status": 301,
      "headers": { "Location": "/story" }
    },
    {
      "src": "/about",
      "dest": "/about.html"
    },
    {
      "src": "/story",
      "dest": "/story.html"
    },
    {
      "src": "/blog",
      "dest": "/blog.html"
    },
    {
      "src": "/university",
      "dest": "/university.html"
    },
    {
      "src": "/products",
      "dest": "/products.html"
    },
    {
      "src": "/quidity-for-founders",
      "dest": "/quidity-for-founders.html"
    },
    {
      "src": "/quidity-for-revops",
      "dest": "/quidity-for-revops.html"
    },
    {
      "src": "/quidity-for-marketers",
      "dest": "/quidity-for-marketers.html"
    },
    {
      "src": "/quidity-for-sales-leaders",
      "dest": "/quidity-for-sales-leaders.html"
    },
    {
      "src": "/quidity-for-sellers",
      "dest": "/quidity-for-sellers.html"
    },
    {
      "src": "/(.*)\\.html",
      "dest": "/$1.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1.html"
    }
  ]
}